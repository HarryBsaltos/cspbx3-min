# ===========================================================================
# Plantilla de variables de entorno
# ---------------------------------------------------------------------------
# Copiá este archivo a `.env` y completá los valores. NUNCA subas .env al
# repositorio: ya está en .gitignore.
# ===========================================================================

# Personal Access Token de GitHub con permisos Contents: Read and write.
# Crear en: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=ghp_pegaste_tu_token_aca

# Dueño y nombre del repositorio donde se leen y suben archivos.
GITHUB_OWNER=tu-usuario
GITHUB_REPO=cspbx3-min

# Rama default (opcional, default: main).
GITHUB_BRANCH=main

# Path del archivo de datos dentro del repo (relativo a la raíz).
GITHUB_INPUT_PATH=data/entrada/CsPbBr3_AA_AA.txt
